# XcodeGen-generated project (regenerate with `bin/regen`)
*.xcodeproj/
*.xcworkspace/
xcuserdata/
DerivedData/

# Build artifacts
build/
.build/

# Swift Package Manager (if added later)
Package.resolved
.swiftpm/

# macOS
.DS_Store

# Swift / debug symbols
*.dSYM
*.dSYM.zip

# Editors
.vscode/
.idea/
*.swp
*~

# Generated Info.plist (we use GENERATE_INFOPLIST_FILE = YES)
Generated/

# Local junk
tmp/
.tmp/

# Sparkle private-key exports — if you ever run `sparkle-keygen --export <path>`,
# the resulting file is the EdDSA private key. Treat like a password.
*.priv
*.priv.key
sparkle-priv*
prbar-key*
