#!/usr/bin/env bash
# Print version metadata derived from the current git state.
#
# Subcommands:
#   marketing  → CFBundleShortVersionString-compatible (e.g. "0.1.0")
#                Always semver-shaped so Apple validators stay happy.
#                Resolved as the latest tag minus the leading "v".
#                Falls back to "0.0.0" when no tag exists.
#   build      → CFBundleVersion (e.g. "47"). Monotonically increasing
#                commit count of HEAD. Stays unique even when marketing
#                hasn't been bumped yet.
#   describe   → human-friendly identifier (e.g. "v0.1.0-3-g1a2b3c4-dirty")
#                used in DMG filenames + the About tab so dev builds
#                don't all collide on the same name.
#   short      → 7-char short SHA of HEAD.
#
# Default is `marketing`. Outside a git checkout (or in a sparse copy
# without history) the script falls back to "0.0.0" / "1" / "unknown"
# so callers don't have to special-case CI shadow clones.
set -euo pipefail
cd "$(dirname "$0")/.."

cmd="${1:-marketing}"

is_git_repo() {
    git rev-parse --is-inside-work-tree >/dev/null 2>&1
}

latest_tag() {
    git describe --tags --abbrev=0 2>/dev/null || true
}

case "$cmd" in
    marketing)
        if is_git_repo; then
            tag="$(latest_tag)"
            echo "${tag#v}" | grep -E '^[0-9]+(\.[0-9]+){0,2}$' || echo "0.0.0"
        else
            echo "0.0.0"
        fi
        ;;
    build)
        if is_git_repo; then
            git rev-list --count HEAD 2>/dev/null || echo 1
        else
            echo 1
        fi
        ;;
    describe)
        if is_git_repo; then
            git describe --tags --always --dirty 2>/dev/null \
                || git rev-parse --short HEAD 2>/dev/null \
                || echo "unknown"
        else
            echo "unknown"
        fi
        ;;
    short)
        if is_git_repo; then
            git rev-parse --short HEAD 2>/dev/null || echo "unknown"
        else
            echo "unknown"
        fi
        ;;
    *)
        echo "usage: $0 {marketing|build|describe|short}" >&2
        exit 64
        ;;
esac
