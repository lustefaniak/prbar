#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")/.."

DEV_DIR="$(xcode-select -p 2>/dev/null || true)"
if [[ "$DEV_DIR" == */CommandLineTools* || -z "$DEV_DIR" ]]; then
  echo "error: install Xcode and run: sudo xcode-select --switch /Applications/Xcode.app/Contents/Developer" >&2
  exit 1
fi

./bin/regen

ARCH="$(uname -m)"

# Tests use default DerivedData (separate from bin/build's build/Debug)
# so the test bundle injection doesn't leave stale frameworks behind.
xcodebuild \
  -project PRBar.xcodeproj \
  -scheme PRBar \
  -configuration Debug \
  -destination "platform=macOS,arch=${ARCH}" \
  test
