#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")/.."

# Verify xcodebuild points at full Xcode, not Command Line Tools
DEV_DIR="$(xcode-select -p 2>/dev/null || true)"
if [[ "$DEV_DIR" == */CommandLineTools* || -z "$DEV_DIR" ]]; then
  cat >&2 <<'EOF'
error: xcodebuild is using Command Line Tools, not full Xcode.

Install Xcode from the App Store, then run:
  sudo xcode-select --switch /Applications/Xcode.app/Contents/Developer

EOF
  exit 1
fi

./bin/regen

ARCH="$(uname -m)"

# Pull version from git so the About tab + DMG filename + Sparkle (when
# it lands) all stay in sync without an extra bump-and-commit step.
# project.yml's MARKETING_VERSION/CURRENT_PROJECT_VERSION still apply
# as fallbacks if these args are dropped.
MARKETING_VERSION="$(./bin/version marketing)"
BUILD_NUMBER="$(./bin/version build)"

xcodebuild \
  -project PRBar.xcodeproj \
  -scheme PRBar \
  -configuration Debug \
  -destination "platform=macOS,arch=${ARCH}" \
  -quiet \
  CONFIGURATION_BUILD_DIR="$(pwd)/build/Debug" \
  MARKETING_VERSION="$MARKETING_VERSION" \
  CURRENT_PROJECT_VERSION="$BUILD_NUMBER" \
  build
