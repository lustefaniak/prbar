#!/usr/bin/env bash
# Build a universal (arm64 + x86_64) PRBar.app and wrap it in a DMG.
# Output: build/release/PRBar-<version>.dmg
#
# Two signing modes, selected by env:
#
#  * Ad-hoc (default): no DEVELOPMENT_TEAM set. CODE_SIGN_IDENTITY="-".
#    First-launch users get a Gatekeeper prompt and have to right-click
#    → Open. Fine for personal builds.
#
#  * Developer ID + notarized: DEVELOPMENT_TEAM=<10-char team id> set.
#    The .app is signed with "Developer ID Application", hardened
#    runtime + timestamp are required (set in project.yml's Release
#    config), the DMG is signed with the same identity, then submitted
#    to Apple's notary service via xcrun notarytool and stapled.
#
#    Notary credentials, two ways:
#      - Local: NOTARY_KEYCHAIN_PROFILE (default "prbar-notary") names
#        a profile previously created with
#        `xcrun notarytool store-credentials`.
#      - CI: NOTARY_API_KEY_PATH + NOTARY_API_KEY_ID + NOTARY_API_ISSUER_ID
#        bypass the keychain (ephemeral runners don't have one). The
#        key file is the .p8 downloaded from App Store Connect.
#
# Used by both local dev and .github/workflows/release.yml on tag pushes.
set -euo pipefail
cd "$(dirname "$0")/.."

DEV_DIR="$(xcode-select -p 2>/dev/null || true)"
if [[ "$DEV_DIR" == */CommandLineTools* || -z "$DEV_DIR" ]]; then
  cat >&2 <<'EOF'
error: xcodebuild is using Command Line Tools, not full Xcode.
Install Xcode from the App Store, then:
  sudo xcode-select --switch /Applications/Xcode.app/Contents/Developer
EOF
  exit 1
fi

# Version + build come from git via bin/version. DMG filename uses the
# richer `git describe` form so dev builds don't all collide on
# PRBar-0.0.0.dmg — tagged builds stay clean ("v0.1.0"), in-between
# builds disambiguate ("v0.1.0-3-g1a2b3c4-dirty").
MARKETING_VERSION="$(./bin/version marketing)"
BUILD_NUMBER="$(./bin/version build)"
VERSION_SUFFIX="$(./bin/version describe)"

ARCHIVE="build/release/PRBar.xcarchive"
APP_DIR="$ARCHIVE/Products/Applications"
APP="$APP_DIR/PRBar.app"
STAGING="build/release/dmg-staging"
DMG="build/release/PRBar-${VERSION_SUFFIX}.dmg"

DEVELOPMENT_TEAM="${DEVELOPMENT_TEAM:-}"
NOTARY_KEYCHAIN_PROFILE="${NOTARY_KEYCHAIN_PROFILE:-prbar-notary}"

XCODEBUILD_SIGNING_ARGS=()
if [[ -n "$DEVELOPMENT_TEAM" ]]; then
  echo "==> Building with Developer ID signing (team $DEVELOPMENT_TEAM)"
  XCODEBUILD_SIGNING_ARGS=(
    CODE_SIGN_STYLE=Manual
    CODE_SIGN_IDENTITY="Developer ID Application"
    DEVELOPMENT_TEAM="$DEVELOPMENT_TEAM"
  )
else
  echo "==> Building ad-hoc signed (set DEVELOPMENT_TEAM to enable Developer ID + notarization)"
fi

rm -rf build/release
mkdir -p build/release

./bin/regen

# `archive` builds Release + universal in one shot. xcodebuild handles
# signing the .app and every nested bundle (Sparkle.framework, its
# XPC services) when CODE_SIGN_IDENTITY + DEVELOPMENT_TEAM are passed.
xcodebuild \
  -project PRBar.xcodeproj \
  -scheme PRBar \
  -configuration Release \
  -destination "generic/platform=macOS" \
  -archivePath "$ARCHIVE" \
  -quiet \
  ARCHS="arm64 x86_64" \
  ONLY_ACTIVE_ARCH=NO \
  MARKETING_VERSION="$MARKETING_VERSION" \
  CURRENT_PROJECT_VERSION="$BUILD_NUMBER" \
  "${XCODEBUILD_SIGNING_ARGS[@]}" \
  archive

if [[ ! -d "$APP" ]]; then
  echo "error: expected app at $APP after archive" >&2
  exit 1
fi

# Verify the binary really is universal — fast sanity check on CI.
EXEC="$APP/Contents/MacOS/PRBar"
if ! lipo -info "$EXEC" 2>/dev/null | grep -q "arm64"; then
  echo "error: $EXEC missing arm64 slice" >&2
  lipo -info "$EXEC" >&2 || true
  exit 1
fi
if ! lipo -info "$EXEC" 2>/dev/null | grep -q "x86_64"; then
  echo "error: $EXEC missing x86_64 slice" >&2
  lipo -info "$EXEC" >&2 || true
  exit 1
fi

if [[ -n "$DEVELOPMENT_TEAM" ]]; then
  # Xcode's archive step does not re-sign Sparkle's bundled helpers
  # (Updater.app, Autoupdate, XPCServices/*.xpc) — they ship with
  # Sparkle's own pre-baked signature which is rejected by Apple's
  # Developer-ID-only notary check. We have to re-sign each one
  # individually with our Developer ID + hardened runtime + timestamp,
  # inside-out, ending with the .app itself.
  #
  # `--preserve-metadata=entitlements` is critical for the XPC
  # services and Updater.app — Sparkle ships them with very specific
  # entitlements that the framework's runtime depends on. Re-signing
  # without preserving them breaks the updater.
  echo "==> Re-signing Sparkle nested binaries"
  IDENT="Developer ID Application"
  SPARKLE="$APP/Contents/Frameworks/Sparkle.framework/Versions/B"
  for nested in \
    "$SPARKLE/Updater.app/Contents/MacOS/Updater" \
    "$SPARKLE/Updater.app" \
    "$SPARKLE/Autoupdate" \
    "$SPARKLE/XPCServices/Downloader.xpc" \
    "$SPARKLE/XPCServices/Installer.xpc"; do
    if [[ -e "$nested" ]]; then
      codesign --force --options=runtime --timestamp \
        --sign "$IDENT" \
        --preserve-metadata=entitlements \
        "$nested"
    fi
  done
  # Sparkle.framework itself, then the app bundle.
  codesign --force --options=runtime --timestamp \
    --sign "$IDENT" \
    "$APP/Contents/Frameworks/Sparkle.framework"
  codesign --force --options=runtime --timestamp \
    --sign "$IDENT" \
    --entitlements Resources/PRBar.entitlements \
    "$APP"

  echo "==> Verifying app signature"
  codesign --verify --deep --strict --verbose=2 "$APP"
fi

# Stage the .app + a symlink to /Applications so the DMG drag-install
# pattern works out of the box.
mkdir -p "$STAGING"
cp -R "$APP" "$STAGING/"
ln -s /Applications "$STAGING/Applications"

hdiutil create \
  -volname "PRBar $MARKETING_VERSION" \
  -srcfolder "$STAGING" \
  -ov \
  -format UDZO \
  "$DMG" >/dev/null

if [[ -n "$DEVELOPMENT_TEAM" ]]; then
  echo "==> Signing DMG"
  codesign --force --sign "Developer ID Application" \
    --timestamp \
    "$DMG"

  echo "==> Submitting to Apple notary service (this can take a few minutes)"
  NOTARY_ARGS=()
  if [[ -n "${NOTARY_API_KEY_PATH:-}" ]]; then
    NOTARY_ARGS=(
      --key "$NOTARY_API_KEY_PATH"
      --key-id "${NOTARY_API_KEY_ID:?NOTARY_API_KEY_ID required when NOTARY_API_KEY_PATH set}"
      --issuer "${NOTARY_API_ISSUER_ID:?NOTARY_API_ISSUER_ID required when NOTARY_API_KEY_PATH set}"
    )
  else
    NOTARY_ARGS=(--keychain-profile "$NOTARY_KEYCHAIN_PROFILE")
  fi
  xcrun notarytool submit "$DMG" "${NOTARY_ARGS[@]}" --wait

  echo "==> Stapling notarization ticket to DMG"
  xcrun stapler staple "$DMG"

  echo "==> Final Gatekeeper check"
  spctl -a -vv -t install "$DMG"

  SIGNED_LABEL="Developer ID, notarized"
else
  SIGNED_LABEL="ad-hoc signed"
fi

echo "Built: $DMG"
echo "      $(du -h "$DMG" | cut -f1) (universal, $SIGNED_LABEL)"
echo "      version $MARKETING_VERSION (build $BUILD_NUMBER, $VERSION_SUFFIX)"
